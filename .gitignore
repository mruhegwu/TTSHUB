# ==============================================================================
# TTSHUB .gitignore
# ==============================================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# ==============================================================================
# Node.js / JavaScript / TypeScript
# ==============================================================================
node_modules/
dist/
build/
.next/
.nuxt/
out/
coverage/
*.lcov
.nyc_output/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# ==============================================================================
# Editors and IDEs
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.suo
*.user
*.userosscache
*.sln.docstates

# ==============================================================================
# Docker
# ==============================================================================
docker-compose.override.yml

# ==============================================================================
# Logs
# ==============================================================================
logs/
*.log

# ==============================================================================
# Alembic (Python DB migrations — keep the versions/ directory, not the local files)
# ==============================================================================
alembic.ini.local
